# Core
SECRET_KEY=change-this-to-something-random-in-production
DATABASE_URL=sqlite:///database.db

# Initial superadmin password (set before first run; omit to auto-generate a random one)
SUPERADMIN_PASSWORD=

# Email (SMTP outbound)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
ADMIN_EMAIL=admin@yourdomain.com

# API key (used by internal automation endpoints)
API_KEY=change-this-api-key-in-production

# WhatsApp — Meta Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=change-this-verify-token-in-production

# WhatsApp — Twilio (alternative provider)
WA_PROVIDER=meta
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_FROM=whatsapp:+14155238886

# Email inbound — IMAP polling
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_KEY=change-imap-key-in-production

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-telegram-secret-in-production

# Slack
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=

# Microsoft Teams
TEAMS_WEBHOOK_URL=

# Translation
TRANSLATE_API_KEY=
TRANSLATE_PROVIDER=google
LIBRETRANSLATE_URL=http://localhost:5000

# Widget CORS (restrict to your domains in production, e.g. https://yourapp.com)
WIDGET_ALLOWED_ORIGINS=*
